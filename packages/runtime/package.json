{
  "name": "@waas/runtime",
  "version": "1.0.0",
  "type": "module",
  "description": "Agent runtime engine for WaaS cognitive agents — Express server, Claude Agent SDK, Redis memory, Telegram transport",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.0",
    "@sentry/node": "^10.43.0",
    "@supabase/supabase-js": "^2.95.3",
    "@waas/shared": "*",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "grammy": "^1.35.0",
    "posthog-node": "^5.21.2",
    "redis": "^5.11.0",
    "ws": "^8.18.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.19.5",
    "@types/ws": "^8.18.0",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3"
  }
}
