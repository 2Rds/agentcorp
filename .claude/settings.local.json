{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash(*)",
      "WebFetch(*)",
      "WebSearch",
      "mcp__plugin_supabase_supabase__*",
      "mcp__claude_ai_Cloudflare_Developer_Platform__*",
      "mcp__claude_ai_Vercel__*",
      "mcp__claude_ai_Linear__*",
      "mcp__claude_ai_Stripe__*",
      "mcp__claude_ai_Context7__*",
      "mcp__context7__*",
      "mcp__claude-in-chrome__*",
      "mcp__ide__*",
      "mcp__mem0__search-memories",
      "mcp__mem0__search_memories",
      "mcp__mem0__add_memory",
      "mcp__mem0__add-memory",
      "mcp__claude_ai_Notion__notion-search",
      "mcp__claude_ai_Notion__notion-fetch",
      "mcp__redis-memory__session-init",
      "mcp__mem0__list_entities",
      "mcp__mem0__get_memories",
      "mcp__redis-memory__memory-stats",
      "mcp__redis-memory__search-memories",
      "mcp__redis-memory__add-memory",
      "mcp__redis-memory__list-memories",
      "mcp__redis-memory__search-cross-agent",
      "Skill(update-config)",
      "mcp__linear__save_issue",
      "Skill(pr-review-toolkit:review-pr)",
      "mcp__claude_ai_Notion__notion-create-pages"
    ],
    "deny": [
      "Bash(rm -rf /*)",
      "Bash(git push --force:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -f:*)"
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "mem0"
  ],
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/release-reminder.sh",
            "timeout": 10,
            "statusMessage": "Checking release status..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/auto-lint.mjs",
            "timeout": 30,
            "statusMessage": "Running eslint --fix..."
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "redis-memory-context@local": true
  },
  "enabledMcpJsonServers": [
    "redis-memory"
  ],
  "teammateMode": "in-process"
}
