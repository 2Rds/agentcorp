{
  "permissions": {
    "allow": [
      "Bash(*)",
      "WebFetch(*)",
      "WebSearch",
      "mcp__plugin_supabase_supabase__*",
      "mcp__claude_ai_Cloudflare_Developer_Platform__*",
      "mcp__claude_ai_Vercel__*",
      "mcp__claude_ai_Linear__*",
      "mcp__claude_ai_Stripe__*",
      "mcp__claude_ai_Context7__*",
      "mcp__context7__*",
      "mcp__claude-in-chrome__*",
      "mcp__ide__*",
      "mcp__mem0__search-memories"
    ],
    "deny": [
      "Bash(rm -rf /*)",
      "Bash(git push --force:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -f:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/block-protected.mjs",
            "timeout": 10,
            "statusMessage": "Checking protected files..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/auto-lint.mjs",
            "timeout": 30,
            "statusMessage": "Running eslint --fix..."
          }
        ]
      }
    ]
  }
}
